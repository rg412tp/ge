# Backend Production Environment
# Copy this to .env.production and fill in your values

# MongoDB - use Docker internal or Hostinger MongoDB
MONGO_URL=mongodb://admin:YOUR_MONGO_PASSWORD@mongo:27017
DB_NAME=ge_question_bank

# CORS - set to your domain
CORS_ORIGINS=https://apps.geniuseducation.co.uk,http://localhost

# Gemini API Key (for AI extraction)
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Object Storage (optional - for cloud image storage)
# Remove if storing images locally
EMERGENT_LLM_KEY=
