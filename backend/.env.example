# Backend Production Environment
# Copy this to .env.production and fill in your values

# MongoDB - use Docker internal or Hostinger MongoDB
MONGO_URL=mongodb://admin:YOUR_MONGO_PASSWORD@mongo:27017
DB_NAME=ge_question_bank

# CORS - set to your domain
CORS_ORIGINS=https://apps.geniuseducation.co.uk,http://localhost

# Gemini API Key (ONLY for topic/difficulty classification - 1 call per paper)
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Mathpix API (for PDF text/LaTeX/image extraction)
MATHPIX_APP_ID=YOUR_MATHPIX_APP_ID
MATHPIX_APP_KEY=YOUR_MATHPIX_APP_KEY

# Object Storage (optional - leave empty for local storage)
EMERGENT_LLM_KEY=
